defdetect_tumor_with_confidence(image_path, model, pca): 
 
    # --- Part 1: Prediction & Confidence --- 
img = cv2.imread(image_path, 0) 
original_img = cv2.imread(image_path) 
 
    # Resize & Preprocess 
img_resized = cv2.resize(img, (128, 128)) 
img_flat = img_resized.flatten().reshape(1, -1) 
img_flat = img_flat / 255.0 
img_pca = pca.transform(img_flat) 
 
    # GET PROBABILITY (The new part) 
    # probabilities will look like: [[0.10, 0.85, 0.02, 0.03]] 
probs = model.predict_proba(img_pca) 
 
    # Get the highest score and the matching class index 
max_prob = np.max(probs)  
prediction_idx = np.argmax(probs) 
 
classes = ['glioma_tumor', 'meningioma_tumor', 'no_tumor', 'pituitary_tumor'] 
result = classes[prediction_idx] 
confidence_score = max_prob * 100  # Convert 0.85 to 85.0 
 
print(f"Prediction: {result}") 
print(f"Confidence: {confidence_score:.2f}%") 
 
    # --- Part 2: Localization (Same as before) --- 
if result == 'no_tumor': 
        # Just show the image with text 
plt.figure(figsize=(6,6)) 
plt.imshow(cv2.cvtColor(original_img, cv2.COLOR_BGR2RGB)) 
plt.title(f"Result: No Tumor ({confidence_score:.1f}%)") 
plt.axis('off') 
plt.show() 
return 
 
    # Localization Logic 
blurred = cv2.GaussianBlur(img_resized, (5, 5), 0) 
    _, thresholded = cv2.threshold(blurred, 45, 255, cv2.THRESH_BINARY) 
contours, _ = cv2.findContours(thresholded, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE) 
 
largest_contour = None 
max_area = 0 
forcnt in contours: 
