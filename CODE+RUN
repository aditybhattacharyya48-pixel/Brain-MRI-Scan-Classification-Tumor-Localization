if area >max_area: 
max_area = area 
largest_contour = cnt 
 
iflargest_contour is not None: 
x, y, w, h = cv2.boundingRect(largest_contour) 
 
        # Scale back to original size 
scale_x = original_img.shape[1] / 128 
